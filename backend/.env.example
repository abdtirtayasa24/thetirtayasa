APP_NAME="Data Analyst & AI Enabler Portfolio API"
APP_ENV=local
BACKEND_CORS_ORIGINS=http://127.0.0.1:3030,http://localhost:3030,https://thetirtayasa.my.id

# Supabase/PostgreSQL server-side connection string. Never expose this to the browser.
DATABASE_URL=postgresql+asyncpg://portfolio_user:replace-with-database-password@localhost:5432/portfolio

# Gemini server-side credentials. Never expose this to the browser.
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_CHAT_MODEL=replace-with-chat-model
GEMINI_EMBEDDING_MODEL=replace-with-embedding-model
GEMINI_EMBEDDING_DIMENSIONS=768

# Internal endpoint protection
INGESTION_SECRET=replace-with-random-secret

# Privacy-preserving AI chat rate limiting
RATE_LIMIT_HMAC_SECRET=replace-with-random-hmac-secret
CHAT_REQUESTS_PER_MINUTE_PER_VISITOR=10
CHAT_REQUESTS_PER_HOUR_PER_SESSION=50
CHAT_MAXIMUM_MESSAGE_CHARACTERS=2000
CHAT_MAXIMUM_CONVERSATION_MESSAGES=20
AI_CHAT_DAILY_REQUEST_LIMIT=500
AI_CHAT_ENABLED=true
